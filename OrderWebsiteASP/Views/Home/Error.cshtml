@model OrderWebsiteASP.ViewModels.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="text-center mt-5">
    <h1 class="text-danger">Something went wrong.</h1>
    <p class="lead">An unexpected error occurred while processing your request.</p>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-success mt-3">
        Back to Home
    </a>
</div>