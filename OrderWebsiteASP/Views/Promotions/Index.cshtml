@model OrderWebsiteASP.ViewModels.PagedResultViewModel<OrderWebsiteASP.Data.Models.Promotion>
@using OrderWebsiteASP.Data.Models

@{
    ViewData["Title"] = "Promotions";
    var restaurants = ViewBag.Restaurants as IEnumerable<Restaurant> ?? Enumerable.Empty<Restaurant>();
}

<h2 class="mb-4">Active Promotions</h2>

@if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-success">Add Promotion</a>
    </p>
}

<form method="get" asp-action="Index" class="row g-3 mb-4">
    <div class="col-md-5">
        <select name="restaurantId" class="form-select">
            <option value="">All restaurants</option>
            @foreach (var restaurant in restaurants)
            {
                if (Model.Pagination.RestaurantId == restaurant.Id)
                {
                    <option value="@restaurant.Id" selected>@restaurant.Name</option>
                }
                else
                {
                    <option value="@restaurant.Id">@restaurant.Name</option>
                }
            }
        </select>
    </div>

    <div class="col-md-4">
        <input type="number"
               step="0.01"
               min="0"
               name="minDiscount"
               value="@Model.Pagination.MinDiscount"
               class="form-control"
               placeholder="Minimum discount %" />
    </div>

    <div class="col-md-3 d-flex gap-2">
        <button type="submit" class="btn btn-success">Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">
        No active promotions match the selected filters.
    </div>
}
else
{
    <div class="row g-4 align-items-start">
        @foreach (var promotion in Model.Items)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card promotion-card shadow-sm">
                    @if (!string.IsNullOrEmpty(promotion.ImageUrl))
                    {
                        <img src="@promotion.ImageUrl" class="card-img-top promotion-card-img" alt="@promotion.Title" />
                    }
                    else
                    {
                        <img src="https://via.placeholder.com/600x200?text=No+Image"
                             class="card-img-top promotion-card-img"
                             alt="No image available" />
                    }

                    <div class="card-body">
                        <h5 class="card-title">@promotion.Title</h5>
                        <p class="card-text">@promotion.Description</p>
                        <p class="card-text fw-bold text-success">@promotion.DiscountPercent% OFF</p>
                        <p class="card-text">
                            <small class="text-muted">@promotion.Restaurant?.Name</small>
                        </p>
                        <p class="card-text">
                            <small class="text-muted">
                                @promotion.StartDate.ToString("dd MMM yyyy") - @promotion.EndDate.ToString("dd MMM yyyy")
                            </small>
                        </p>

                        <div class="d-flex flex-wrap gap-2 mt-2">
                            <a asp-action="Details" asp-route-id="@promotion.Id" class="btn btn-outline-success btn-sm">
                                Details
                            </a>

                            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@promotion.Id" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@promotion.Id" class="btn btn-danger btn-sm">Delete</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<partial name="_PaginationPartial" model="Model.Pagination" />