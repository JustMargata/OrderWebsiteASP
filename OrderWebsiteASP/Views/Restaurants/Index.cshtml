@model OrderWebsiteASP.ViewModels.PagedResultViewModel<OrderWebsiteASP.Data.Models.Restaurant>
@using Microsoft.AspNetCore.Identity
@using OrderWebsiteASP.Data.Models
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Restaurants";
}

<h2 class="mb-4">All Restaurants</h2>

@if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Add New Restaurant</a>
    </p>
}

<div class="row">
    @foreach (var restaurant in Model.Items)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(restaurant.ImageUrl))
                {
                    <img src="@restaurant.ImageUrl" class="card-img-top" alt="@restaurant.Name" />
                }

                <div class="card-body">
                    <h5 class="card-title">@restaurant.Name</h5>
                    <p class="card-text">@restaurant.Address</p>
                    <p class="card-text">
                        <small class="text-muted">
                            @(restaurant.FoodItems?.Count ?? 0) dishes available
                        </small>
                    </p>

                    <a asp-action="Details" asp-route-id="@restaurant.Id" class="btn btn-outline-primary">
                        View Menu
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<partial name="_PaginationPartial" model="Model.Pagination" />