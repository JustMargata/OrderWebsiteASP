@model OrderWebsiteASP.ViewModels.PagedResultViewModel<OrderWebsiteASP.Data.Models.Restaurant>

@{
    ViewData["Title"] = "Restaurants";
}

<h2 class="mb-4">All Restaurants</h2>

@if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-success">Add New Restaurant</a>
    </p>
}

<div class="row g-4 align-items-start">
    @foreach (var restaurant in Model.Items)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card restaurant-card shadow-sm">
                @if (!string.IsNullOrEmpty(restaurant.ImageUrl))
                {
                    <img src="@restaurant.ImageUrl" class="card-img-top restaurant-card-img" alt="@restaurant.Name" />
                }
                else
                {
                    <img src="https://via.placeholder.com/600x200?text=No+Image" class="card-img-top restaurant-card-img" alt="No image available" />
                }

                <div class="card-body">
                    <h5 class="card-title">@restaurant.Name</h5>
                    <p class="card-text">@restaurant.Address</p>
                    <p class="card-text">
                        <small class="text-muted">
                            @(restaurant.FoodItems?.Count ?? 0) dishes available
                        </small>
                    </p>

                    <a asp-action="Details" asp-route-id="@restaurant.Id" class="btn btn-outline-success">
                        View Menu
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<partial name="_PaginationPartial" model="Model.Pagination" />